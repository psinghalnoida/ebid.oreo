# Copy this file to .env and fill in real values.
# NEVER commit the real .env file — it is git-ignored by design.

# ── App ──────────────────────────────────────────────────────────
NODE_ENV=development
BACKEND_PORT=4000
FRONTEND_PORT=5173
APP_BASE_URL=http://localhost:5173

# ── Database (PostgreSQL) ───────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ebidhub
POSTGRES_USER=ebidhub_app
POSTGRES_PASSWORD=change_me_local_dev_only

# ── Redis (live bidding state, BullMQ job queue) ────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Auth ─────────────────────────────────────────────────────────
# Standard users: mobile + OTP + mPIN (BR-02). No third-party IdP.
JWT_SECRET=change_me_generate_a_real_random_secret

# Super Admin only: TOTP/MFA via Auth0 (BR-04, BR-20). TBD until
# Super Admin auth is implemented — not needed for early dev.
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# ── SMS OTP provider (BR-02) — TBD, stub/mock until selected ────
SMS_PROVIDER=stub
SMS_API_KEY=

# ── Payment Gateway / EMD routing (BR-26) — TBD, stub until selected ──
PAYMENT_GATEWAY_PROVIDER=stub
PAYMENT_GATEWAY_KEY=
PAYMENT_GATEWAY_SECRET=

# ── Bank verification / penny-drop (BR-18) — TBD, stub until selected ──
BANK_VERIFICATION_PROVIDER=stub
BANK_VERIFICATION_API_KEY=

# ── AI Listing Pre-Audit (BR-46) ────────────────────────────────
GEMINI_API_KEY=

# ── Error monitoring ─────────────────────────────────────────────
SENTRY_DSN=
